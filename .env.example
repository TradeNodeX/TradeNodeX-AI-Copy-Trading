APP_ENV=local
DATABASE_URL=sqlite+aiosqlite:///./copytrading.db
DB_ECHO=false
BINANCE_BASE_URL=https://testnet.binancefuture.com
BINANCE_WS_BASE_URL=wss://stream.binancefuture.com
BYBIT_BASE_URL=https://api-testnet.bybit.com
BYBIT_WS_BASE_URL=wss://stream-testnet.bybit.com
API_TIMEOUT_SECONDS=10.0
DEFAULT_RECV_WINDOW_MS=5000
SERVICE_NAME=private-copytrading-system
AWS_REGION=ap-northeast-1
QUEUE_BACKEND=memory
SQS_QUEUE_URL_NORMAL=
SQS_QUEUE_URL_RISK=
SQS_QUEUE_URL_RECOVERY=
REDIS_URL=redis://localhost:6379/0
REDIS_PREFIX=copytrading
KMS_BACKEND=local
KMS_KEY_ID=
DEFAULT_ENVIRONMENT=TESTNET
SERVE_FRONTEND=true
DEFAULT_QUEUE_VISIBILITY_SECONDS=30
RECONCILER_TOLERANCE=0.000001
